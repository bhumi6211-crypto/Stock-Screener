'use client';
import { useEffect } from 'react';
import { useRouter } from 'next/navigation';

export default function Home() {
  const router = useRouter();

  useEffect(() => {
    const token = typeof window !== 'undefined' ? localStorage.getItem('pip_token') : null;
    if (token) {
      router.replace('/dashboard');
    } else {
      router.replace('/login');
    }
  }, [router]);

  return (
    <div style={{ display: 'flex', justifyContent: 'center', alignItems: 'center', minHeight: '100vh', flexDirection: 'column', gap: '16px' }}>
      <div style={{ fontSize: '48px' }}>📊</div>
      <h1 style={{ fontSize: '28px', fontWeight: 'bold', color: '#1e40af' }}>Portfolio Insight Pro</h1>
      <p style={{ color: '#6b7280' }}>Loading...</p>
    </div>
  );
}
