# ============================================================================
# DATABASE (Required)
# ============================================================================
# Free option: Neon PostgreSQL (https://neon.tech)
# Copy connection string from Neon dashboard
DATABASE_URL="postgresql://username:password@host.neon.tech/dbname?sslmode=require"

# ============================================================================
# AUTHENTICATION (Required)
# ============================================================================
# Generate random string: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
NEXTAUTH_URL="http://localhost:3000"

# ============================================================================
# API KEYS (Free Tiers)
# ============================================================================
# NewsAPI (https://newsapi.org) - Free tier: 100 requests/day
NEWSAPI_KEY="your-newsapi-key-here"

# FinnHub (https://finnhub.io) - Free tier: 60 requests/minute
FINNHUB_API_KEY="your-finnhub-key-here"

# ============================================================================
# BROKER INTEGRATION (Optional)
# ============================================================================
# Zerodha (https://zerodha.com)
# Users provide credentials via web UI, not hardcoded here
ZERODHA_REDIRECT_URL="http://localhost:3000/api/auth/zerodha/callback"

# ============================================================================
# APPLICATION (Config)
# ============================================================================
# Frontend URL
NEXT_PUBLIC_API_URL="http://localhost:3000"

# Node environment
NODE_ENV="development"

# News fetch schedule (cron format)
# "0 8 * * *" = 8:00 AM every day (IST)
NEWS_FETCH_SCHEDULE="0 8 * * *"
NEWS_FETCH_SCHEDULE_PM="0 20 * * *"

# ============================================================================
# STOCK DATA SOURCES (Config)
# ============================================================================
# Primary source for stock prices and fundamentals
PRIMARY_STOCK_SOURCE="yfinance" # yfinance, screener, nse

# Update interval (minutes)
STOCK_DATA_UPDATE_INTERVAL="60"

# ============================================================================
# FEATURES (Toggle)
# ============================================================================
# Enable/disable features
ENABLE_LIVE_TRADING="false"
ENABLE_AUTO_TRADING="true"
ENABLE_BACKTESTING="false"
ENABLE_ML_RECOMMENDATIONS="true"

# ============================================================================
# LOGGING (Optional)
# ============================================================================
LOG_LEVEL="info" # debug, info, warn, error
DEBUG_MODE="false"
